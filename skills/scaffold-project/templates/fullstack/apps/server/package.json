{
  "name": "server",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-arm64 --outfile ./server ./src/index.ts",
    "build:linux-x64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-x64 --outfile ./server ./src/index.ts",
    "build:linux-arm64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-linux-arm64 --outfile ./server ./src/index.ts",
    "build:mac-x64": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-darwin-x64 --outfile ./server ./src/index.ts",
    "build:windows": "NODE_ENV=production bun build --compile --minify-whitespace --minify-syntax --target bun-windows-x64 --outfile ./server.exe ./src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "test": "bun test tests",
    "test:watch": "bun test --watch tests",
    "coverage:report": "bun test --coverage tests"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@repo/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "bun-types": "latest",
    "consola": "^3.4.2",
    "drizzle-kit": "^0.31.10"
  }
}
