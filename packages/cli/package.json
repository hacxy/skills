{
  "name": "@hacxy/skills",
  "version": "0.0.4",
  "description": "CLI for managing and installing skills across Cursor, Claude Code, and Codex.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "bump": "bump"
  },
  "keywords": [
    "skills",
    "cursor",
    "claude-code",
    "codex",
    "cli"
  ],
  "author": "hacxy",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skills": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "types": "dist/index.d.ts",
  "dependencies": {
    "chalk": "^5.6.2",
    "fast-glob": "^3.3.3",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@hacxy/bump": "^0.4.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
